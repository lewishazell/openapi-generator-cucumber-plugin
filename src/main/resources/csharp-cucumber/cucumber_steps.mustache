                    if (!actualObj.TryGetValue(property.Name, out var actualValue) || !ContainsSubtree(actualValue, property.Value))
                    {
                        return false;
                    }
                }
                return true;
            }
            else if (expected.Type == JTokenType.Array)
            {
                var expectedArr = (JArray)expected;
                var actualArr = actual as JArray;
                if (actualArr == null) return false;
                foreach (var expectedElem in expectedArr)
                {
                    if (!actualArr.Any(a => ContainsSubtree(a, expectedElem)))
                    {
                        return false;
                    }
                }
                return true;
            }
            else
            {
                return JToken.DeepEquals(actual, expected);
            }
        }

