        private static bool ContainsSubtree(JToken actual, JToken expected)
        {
            if (expected.Type == JTokenType.Object)
            {
                var expectedObj = (JObject)expected;
                var actualObj = actual as JObject;
                if (actualObj == null) return false;
                foreach (var property in expectedObj.Properties())
