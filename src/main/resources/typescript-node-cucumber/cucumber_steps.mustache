When('the request is sent', async function() {
    {{#apiInfo.apis}}
    if (ctx.request?.classname == "{{#lambda.pascalcase}}{{classname}}{{/lambda.pascalcase}}") {
        const api: {{classname}} = new {{classname}}(ctx.targetHost);
        {{#hasHttpBearerMethods}}

        if (ctx.accessToken) {
            api.accessToken = ctx.accessToken;
        }
        {{/hasHttpBearerMethods}}
        {{#hasApiKeyMethods}}

        if (ctx.apiKey)
        {
            if (!ctx.securityScheme) {
                throw new Error("Missing required configuration: 'cucumber_security_scheme'. When using an API key, please also set the cucumber_security_scheme environment variable");
            }

            if (ctx.apiKeyPrefix) {
                ctx.apiKey = `${ctx.apiKeyPrefix} ${ctx.apiKey}`;
            }

            api.setApiKey({{classname}}ApiKeys[ctx.securityScheme as keyof typeof {{classname}}ApiKeys], ctx.apiKey);
        }
        {{/hasApiKeyMethods}}
        {{#operations}}
        {{#operation}}

        if (ctx.request.operationId == "{{#lambda.camelcase}}{{operationId}}{{/lambda.camelcase}}") {
            let { response, body } = await api.{{operationId}}({{#allParams}}ctx.request.parameters["{{baseName}}"]{{^-last}}, {{/-last}}{{/allParams}});
            ctx.response = { message: response, body };

            return;
        }
        {{/operation}}
        {{/operations}}
    }
    {{/apiInfo.apis}}

    throw new Error(`${ctx.request?.classname}.${ctx.request?.operationId} does not exist`);
});

Then('the response status should be {int}', function(statusCode: string) {
    assert.strictEqual(ctx.response?.message.statusCode, parseInt(statusCode), `Expected response status to be ${statusCode} but got ${ctx.response?.message.statusCode}`);
});

Then('the response content should be:', function(content: string) {
    const { type } = contentType.parse(ctx.response?.message.headers["content-type"]!);

    if (type == "application/json") {
        const actual: any = JSON.parse(JSON.stringify(ctx.response?.body));
        const expected: any = JSON.parse(content);

        assert.deepStrictEqual(actual, expected, `Expected response data to be '${content}' but got '${JSON.stringify(actual)}'`);
    } else {
        throw new Error("Cannot assert against unsupported content type: " + type);
    }
});

Then('the response content should contain the subtree:', function(content: string) {
    const { type } = contentType.parse(ctx.response?.message.headers["content-type"]!);

    if (type == "application/json") {
        const actual: any = JSON.parse(JSON.stringify(ctx.response?.body));
        const expected: any = JSON.parse(content);

        function containsSubtree(actual: any, expected: any): boolean {
            if (typeof expected !== 'object' || expected === null) {
                return actual === expected;
            }
            if (Array.isArray(expected)) {
                if (!Array.isArray(actual)) return false;
                for (const expectedItem of expected) {
                    if (!actual.some((actualItem: any) => containsSubtree(actualItem, expectedItem))) {
                        return false;
                    }
                }
                return true;
            }
            for (const key in expected) {
                if (!(key in actual)) return false;
                if (!containsSubtree(actual[key], expected[key])) return false;
            }
            return true;
        }

        assert.ok(containsSubtree(actual, expected), `Response does not contain the expected subtree: ${content}`);
    } else {
        throw new Error("Cannot assert against unsupported content type: " + type);
    }
});

class Request {
    private _classname: string;
    private _operationId: string;
    private _parameters: { [name: string]: any } = {};

    public constructor(classname: string, operationId: string) {
        this._classname = classname;
        this._operationId = operationId;
    }

    public get classname(): string {
        return this._classname;
    }

    public get operationId(): string {
        return this._operationId;
    }

    public get parameters(): { [name: string]: any } {
        return this._parameters;
    }
}