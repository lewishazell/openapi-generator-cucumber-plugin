class TestContext {
    public request: Request | undefined;
    public response: { message: http.IncomingMessage, body: any } | undefined;
    public targetHost: string | undefined;
    public accessToken: string | undefined;
    public securityScheme: string | undefined;
    public apiKey: string | undefined;
    public apiKeyPrefix: string | undefined;
}

const ctx = new TestContext();

Before(function() {
    const defaultHost: string = "{{cucumberTargetHost}}";

    ctx.targetHost = process.env.cucumber_target_host;
    ctx.accessToken = process.env.cucumber_access_token?.trim();
    ctx.securityScheme = process.env.cucumber_security_scheme?.trim();
    ctx.apiKey = process.env.cucumber_api_key?.trim();
    ctx.apiKeyPrefix = process.env.cucumber_api_key_prefix?.trim();

    if (!ctx.targetHost) {
        ctx.targetHost = defaultHost;
    }

    if (!ctx.targetHost) {
        throw new Error("Missing required configuration: 'cucumber_target_host'. Please set the cucumber_target_host environment variable, or pass it during generation with -p cucumberTargetHost=http://your-api");
    }

    {{^hasHttpBearerMethods}}
    if (ctx.accessToken) {
        throw new Error("An access token has been set but the OpenAPI specification has no HTTP bearer authentication methods");
    }
    {{/hasHttpBearerMethods}}

    {{^hasApiKeyMethods}}
    if (ctx.apiKey) {
        throw new Error("An API key has been set but the OpenAPI specification has no API key authentication methods");
    }
    {{/hasApiKeyMethods}}
});

